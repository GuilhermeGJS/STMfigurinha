# Database (PostgreSQL)
# Local dev: postgresql://postgres:postgres@localhost:5432/stickershop
# Render: auto-provided by Render PostgreSQL service
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stickershop"

# NextAuth
AUTH_SECRET="change-me-to-a-random-string-32-chars"
AUTH_URL="http://localhost:3000"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Resend (Emails)
RESEND_API_KEY="re_..."

# Upload (local for dev, R2/S3 for production)
UPLOAD_PROVIDER="local"
